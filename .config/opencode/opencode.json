{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "opencodex-fast@latest",
    "opencode-claude-auth@v1.4.10"
  ],
  "permission": {
    "read": {
      "/Users/liamaharon/.cargo/registry/**": "allow"
    },
    "glob": {
      "/Users/liamaharon/.cargo/registry/**": "allow"
    },
    "grep": {
      "/Users/liamaharon/.cargo/registry/**": "allow"
    },
    "list": {
      "/Users/liamaharon/.cargo/registry/**": "allow"
    },
    "external_directory": {
      "/Users/liamaharon/.cargo/registry/**": "allow"
    },
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "rm *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "diskutil erase*": "ask",
      "shutdown *": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "poweroff*": "ask",
      "git commit*": "allow",
      "git push*": "allow",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git push --force-with-lease*": "ask",
      "git push --delete*": "ask",
      "git push --mirror*": "ask",
      "git push --prune*": "ask",
      "git push * :*": "ask",
      "git reset*": "ask",
      "git clean*": "ask",
      "git checkout --*": "ask",
      "git restore --source*": "ask",
      "git branch -D*": "ask"
    }
  }
}
